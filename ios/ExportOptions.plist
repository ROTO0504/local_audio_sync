<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Store Connect(TestFlight)へ自動署名で直接アップロードする設定。
	     Runner と BroadcastExtension の2ターゲットを、App Store Connect API キー +
	     -allowProvisioningUpdates で自動プロビジョニングする(macOS 側と同じ方式)。
	     以前は Runner のみ手動プロファイル指定だったが、Extension 追加に伴い
	     自動署名へ統一した(Extension 用プロファイルを手で用意せずに済む)。 -->
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>upload</string>
	<key>signingStyle</key>
	<string>automatic</string>
	<key>teamID</key>
	<string>7H7U867AYF</string>
	<!-- ビルド番号は CI が --build-number で採番するため Xcode 側では管理しない -->
	<key>manageAppVersionAndBuildNumber</key>
	<false/>
	<key>uploadSymbols</key>
	<true/>
</dict>
</plist>
